# Dokploy / Docker Compose environment example.
# Copy these variables to Dokploy's Environment tab, or create a local .env file.

# Compatible mode: the browser keeps using its own API Key, and the server proxy is optional.
DEFAULT_API_URL=https://api.openai.com/v1
API_PROXY_URL=https://api.openai.com/v1
ENABLE_API_PROXY=false
LOCK_API_PROXY=false

# Server-managed mode: set SERVER_API_CONFIG_ENABLED=true to hide and lock the API config.
# Public deployments should add authentication, VPN, IP allowlist, or gateway rate limits.
SERVER_API_CONFIG_ENABLED=false
SERVER_API_UPSTREAM_URL=https://api.openai.com/v1
SERVER_API_KEY=
SERVER_API_MODEL=gpt-image-2
SERVER_API_MODE=images
SERVER_API_CODEX_CLI=false
SERVER_API_RESPONSE_FORMAT_B64_JSON=false
SERVER_API_TIMEOUT_SECONDS=600

# Restricted Agent mode (trusted intranet): enable the Agent switch below, then run
# `docker compose up -d --build`. The Gateway stays health-only while this switch is false.
RESTRICTED_AGENT_ENABLED=false
# Optional: hide the gallery and Legacy Agent entry when the restricted Agent is enabled.
# Restricted mode always disables /api-proxy; Legacy browser-direct mode remains available only when this is false.
RESTRICTED_AGENT_ONLY=false
AGENT_PUBLIC_ORIGIN=https://image.example.internal
AGENT_SESSION_SECRET=
AGENT_UPSTREAM_BASE_URL=https://api.openai.com/v1
AGENT_API_KEY=
AGENT_PLANNER_MODEL=gpt-5.5
AGENT_IMAGE_MODEL=gpt-image-2

# Non-secret policy limits. The Gateway capability endpoint publishes the effective values.
AGENT_PLAN_TTL_SECONDS=900
AGENT_ASSET_TTL_SECONDS=86400
AGENT_MAX_REFERENCE_IMAGES=16
AGENT_MAX_FILE_BYTES=20971520
AGENT_MAX_UPLOAD_BYTES=134217728
AGENT_MAX_IMAGE_PIXELS=40000000
AGENT_MAX_OUTPUT_IMAGES=4
AGENT_MAX_QUEUE=10
AGENT_MAX_CONCURRENCY=2
AGENT_PLAN_RATE_PER_MINUTE=5
AGENT_EXECUTE_RATE_PER_MINUTE=2
AGENT_IMAGES_RATE_PER_HOUR=20
AGENT_PLANNER_TIMEOUT_MS=60000
AGENT_EXECUTOR_TIMEOUT_MS=180000
AGENT_REQUEST_TIMEOUT_SECONDS=600
AGENT_LOG_LEVEL=info
